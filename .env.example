# HomeKeep configuration
# Copy to .env and customize. Do NOT commit .env.

# Public URL of the app as end users reach it.
# Used for PWA manifest and ntfy notification links.
# NOTE: no trailing slash (see 04-RESEARCH Pitfall 9). The invite-URL
# builder strips trailing slashes defensively anyway, but keep this
# tidy by convention.
SITE_URL=http://localhost:3000

# Notifications (Phase 6)
# ntfy server URL (public or self-hosted). Default https://ntfy.sh.
# See D-01: sends via POST ${NTFY_URL}/${topic} with plain text body.
# Test: curl -d "test" https://ntfy.sh/<your-topic>
NTFY_URL=https://ntfy.sh

# Set to 'true' to disable the in-process scheduler (tests, CI, etc).
# Leave unset in production; dev defaults to enabled. (D-09)
DISABLE_SCHEDULER=

# Token for POST /api/admin/run-scheduler (manual tick + E2E).
# MUST be >= 32 chars. Rotate in production.
ADMIN_SCHEDULER_TOKEN=

# Timezone for scheduler and date display (IANA name)
TZ=Australia/Melbourne

# Host UID/GID for the ./data volume owner
# Match to your host user: run `id -u` and `id -g`
PUID=1000
PGID=1000

# SMTP (optional — enables password reset via AUTH-04)
# If unset, password reset silently no-ops with a "contact admin" message per D-02.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=HomeKeep
SMTP_TLS=true

# PocketBase superuser credentials (required for invite acceptance
# admin-client path — see lib/pocketbase-admin.ts + 04-01 SUMMARY).
# Create via `./pocketbase superuser create <email> <password>` on
# first boot, then paste here. NEVER commit real values.
# acceptInvite will throw a clear
#   "PB_ADMIN_EMAIL / PB_ADMIN_PASSWORD not configured"
# error if either is missing.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# HTTPS variant: Caddy + public domain (see docker-compose.caddy.yml).
# Set DOMAIN before using the caddy overlay; Caddy auto-provisions a
# Let's Encrypt cert on first hit. Point an A record for this domain at
# your VPS public IP first, and open TCP 80 + 443 on the firewall.
DOMAIN=
# Contact email for Let's Encrypt registration (defaults to admin@${DOMAIN} if unset).
CADDY_EMAIL=

# Tailscale variant (see docker-compose.tailscale.yml).
# Generate a Reusable auth key at https://login.tailscale.com/admin/settings/keys
# (Ephemeral optional) and paste the tskey-auth-... value here.
TS_AUTHKEY=
