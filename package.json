{
  "name": "homekeep",
  "version": "1.2.1",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,pb -c cyan,magenta \"npm:dev:next\" \"npm:dev:pb\"",
    "dev:next": "next dev --port 3001",
    "dev:pb": "node scripts/dev-pb.js",
    "build": "next build --webpack",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docker:build": "docker buildx build --platform linux/amd64 -t homekeep:dev --load -f docker/Dockerfile .",
    "docker:run": "docker run --rm -p 3000:3000 -v \"$(pwd)/data:/app/data\" --env-file .env homekeep:dev"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hookform/resolvers": "5.2.2",
    "@serwist/next": "9.5.7",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "lucide-react": "1.8.0",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "node-cron": "3.0.3",
    "pocketbase": "0.26.8",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "serwist": "9.2.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.17",
    "@types/node-cron": "3.0.11",
    "@types/react": "19.2.5",
    "@types/react-dom": "19.2.3",
    "@types/serviceworker": "0.0.180",
    "@vitejs/plugin-react": "5.0.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "jsdom": "29.0.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
